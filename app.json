{
  "expo": {
    "name": "fufu",
    "slug": "fufu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3E9DA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fufuapp.fufu",
      "infoPlist": {
        "NSCameraUsageDescription": "fufu needs camera access to scan product barcodes and ingredient labels.",
        "NSPhotoLibraryUsageDescription": "fufu needs photo library access to scan ingredient labels from saved images."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ],
      "package": "com.fufuapp.fufu"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "platforms": ["ios", "android"],
    "scheme": "foodsafety",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "fufu needs camera access to scan product barcodes and ingredient labels."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc5e0293-220f-4db7-b94c-11ad1f7ce7c4"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cc5e0293-220f-4db7-b94c-11ad1f7ce7c4"
    }
  }
}
